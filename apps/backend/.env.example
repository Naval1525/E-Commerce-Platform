PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/ecommerce_platform

# Comma-separated list of frontend origins allowed by CORS. Any origin ending with .vercel.app is also allowed when this is set.
CORS_ORIGIN=https://e-commerce-platform-frontend-do7kdupol-naval1525s-projects.vercel.app,http://localhost:5173
# If no auth token is provided, APIs like cart/checkout use this seeded demo user.
DEFAULT_USER_EMAIL=demo@flipkart-clone.local
JWT_SECRET=replace_with_a_long_random_string

# Email (Gmail app password)
# 1) Enable 2FA on your Google Account
# 2) Generate an "App Password" for Mail
# 3) Set these values and restart the backend
GMAIL_USER=yourgmail@gmail.com
GMAIL_APP_PASSWORD=your_app_password
# Wrap in quotes because it contains spaces/angle brackets.
MAIL_FROM="Flipkart Clone <yourgmail@gmail.com>"
# Optional overrides
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=465
# MAIL_SECURE=1
