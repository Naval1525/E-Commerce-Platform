  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "npx tsx watch src/app/server.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --check .",
    "prisma:generate": "prisma generate",
